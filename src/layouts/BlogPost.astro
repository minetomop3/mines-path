---
import BaseLayout from './BaseLayout.astro';
import AdPlaceholder from '../components/AdPlaceholder.astro';
import { url } from '../utils/url';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, category, categorySlug, tags, keywords, heroImage } = post.data;
const imgSrc = heroImage ? `${import.meta.env.BASE_URL.replace(/\/$/, '')}${heroImage}` : null;

const formattedDate = pubDate.toLocaleDateString('ja-JP', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<BaseLayout title={title} description={description} keywords={keywords}>
  <article class="blog-post">
    {imgSrc && (
      <div class="post-hero-image">
        <img src={imgSrc} alt={title} loading="eager" />
      </div>
    )}

    <header class:list={['post-header', { 'post-header--no-image': !imgSrc }]}>
      <div class="content-container">
        <nav class="breadcrumb" aria-label="パンくずリスト">
          <a href={url('/')}>Home</a>
          <span aria-hidden="true"> › </span>
          <a href={url(`/category/${categorySlug}`)}>{category}</a>
          <span aria-hidden="true"> › </span>
          <span>{title.substring(0, 30)}{title.length > 30 ? '...' : ''}</span>
        </nav>

        <div class="post-header-meta">
          <a href={url(`/category/${categorySlug}`)} class="category-badge" data-category={categorySlug}>
            {category}
          </a>
          <time datetime={pubDate.toISOString()} class="post-date">{formattedDate}</time>
        </div>

        <h1 class="post-title">{title}</h1>
        <p class="post-description">{description}</p>

        {tags.length > 0 && (
          <div class="post-tags">
            {tags.map(tag => <span class="post-tag">#{tag}</span>)}
          </div>
        )}
      </div>
    </header>

    <div class="content-container">
      <AdPlaceholder slot="header" label="広告" />
    </div>

    <div class="content-container">
      <div class="prose article-body">
        <slot />
      </div>
    </div>

    <div class="content-container">
      <AdPlaceholder slot="footer" label="広告" />
    </div>

    <footer class="post-footer content-container">
      <a href={url('/blog')} class="btn btn-outline">← 記事一覧へ戻る</a>
      <a href={url(`/category/${categorySlug}`)} class="btn btn-outline">
        {category} の記事をもっと見る
      </a>
    </footer>
  </article>
</BaseLayout>

<style>
.post-hero-image { width: 100%; max-height: 480px; overflow: hidden; background: var(--color-surface); }
.post-hero-image img { width: 100%; height: 480px; object-fit: cover; object-position: center; display: block; }
.post-header { padding: var(--space-xl) 0; border-bottom: 1px solid var(--color-border); margin-bottom: var(--space-xl); background: var(--color-bg); }
.post-header--no-image { padding-top: var(--space-2xl); background: linear-gradient(to bottom, var(--color-surface) 0%, var(--color-bg) 100%); }
.breadcrumb { font-size: 0.8rem; color: var(--color-text-faint); margin-bottom: var(--space-lg); display: flex; align-items: center; gap: var(--space-xs); flex-wrap: wrap; }
.breadcrumb a { color: var(--color-text-faint); text-decoration: none; }
.breadcrumb a:hover { color: var(--color-accent); }
.post-header-meta { display: flex; align-items: center; gap: var(--space-md); margin-bottom: var(--space-lg); }
.post-date { font-size: 0.85rem; color: var(--color-text-faint); }
.post-title { font-size: clamp(1.5rem, 4vw, 2.25rem); font-weight: 700; line-height: 1.3; margin-bottom: var(--space-lg); color: var(--color-text); }
.post-description { font-size: 1rem; color: var(--color-text-muted); line-height: 1.7; margin-bottom: var(--space-lg); max-width: 680px; padding-left: var(--space-md); border-left: 3px solid var(--color-accent-dim); }
.post-tags { display: flex; flex-wrap: wrap; gap: var(--space-sm); }
.post-tag { font-size: 0.78rem; color: var(--color-text-faint); background: var(--color-surface); border: 1px solid var(--color-border); padding: 3px 10px; border-radius: 100px; }
.article-body { padding: var(--space-xl) 0; }
.post-footer { display: flex; gap: var(--space-md); flex-wrap: wrap; padding: var(--space-2xl) var(--space-lg); border-top: 1px solid var(--color-border); margin-top: var(--space-2xl); }
</style>
