---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import AdPlaceholder from '../components/AdPlaceholder.astro';
import { getCollection } from 'astro:content';
import { url } from '../utils/url';
import { mbaGroups } from '../data/mbaGroups';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categories = [
  { slug: 'mba',   label: '経営学 / MBA',       desc: 'ビジネス戦略・フレームワーク・経営思想',   icon: '📊', color: 'var(--cat-mba)'   },
  { slug: 'tech',  label: 'AI・プログラミング',  desc: 'Claude API・機械学習・開発ノウハウ',       icon: '⚙️', color: 'var(--cat-tech)'  },
  { slug: 'essay', label: '日々のエッセイ',       desc: '思考の断片・日常観察・生き方',             icon: '✍️', color: 'var(--cat-essay)' },
  { slug: 'novel', label: '小説・創作',           desc: '短編小説・詩・インタラクティブ作品',       icon: '📖', color: 'var(--cat-novel)' },
];

// 最新記事
const latestPosts = allPosts.slice(0, 6);

// 人気記事
const popularSlugs = [
  'nba775177db94',
  'tech-obsidian-pkm-guide',
  'essay-walking-life-change',
  'na7a348f6a1d8',
];
const popularPosts = popularSlugs
  .map(slug => allPosts.find(p => p.slug === slug))
  .filter(Boolean);

// 経営学サブカテゴリ（各グループ最大3件）
const mbaPosts = allPosts.filter(p => p.data.categorySlug === 'mba');
const mbaGroupsWithPosts = mbaGroups.map(group => ({
  ...group,
  posts: group.slugs
    .map(s => mbaPosts.find(p => p.slug === s))
    .filter(Boolean)
    .slice(0, 3),
}));
---

<BaseLayout title="Home">
  <!-- ======================================================
       Hero Section
  ====================================================== -->
  <section class="hero">
    <div class="hero-inner container">
      <div class="hero-tag">Personal Blog</div>
      <h1 class="hero-title">
        人生を豊かにする<br />知恵と物語
      </h1>
      <p class="hero-lead">
        MBA経営学の思考法、AIとプログラミングの実践、<br class="br-desktop" />
        日々の観察、そして小説という創造——<br />
        <strong>mines-path</strong>へようこそ。
      </p>
      <div class="hero-actions">
        <a href={url('/blog')} class="btn btn-primary">全記事を読む</a>
        <a href={url('/about')} class="btn btn-outline">About</a>
      </div>
    </div>
    <div class="scroll-hint" aria-hidden="true">
      <span class="scroll-hint-text">SCROLL</span>
      <div class="scroll-hint-line">
        <div class="scroll-hint-dot"></div>
      </div>
    </div>
  </section>

  <!-- ======================================================
       Latest Posts
  ====================================================== -->
  <section class="section-block section-latest">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">最新記事</h2>
        <a href={url('/blog')} class="view-all">すべて見る →</a>
      </div>
      <div class="posts-grid">
        {latestPosts.map(post => <PostCard post={post} />)}
      </div>
    </div>
  </section>

  <!-- ======================================================
       Popular Posts
  ====================================================== -->
  <section class="section-block section-popular">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">人気記事</h2>
        <a href={url('/blog')} class="view-all">すべて見る →</a>
      </div>
      <div class="featured-grid">
        {popularPosts.map(post => post && <PostCard post={post} featured={true} />)}
      </div>
    </div>
  </section>

  <!-- Ad -->
  <div class="container ad-wrap">
    <AdPlaceholder slot="in-article" label="広告" />
  </div>

  <!-- ======================================================
       Category Showcase
  ====================================================== -->
  <section class="section-block section-categories">
    <div class="container">
      <h2 class="section-title section-title--center">カテゴリ</h2>
      <div class="category-grid">
        {categories.map(cat => (
          <a href={url(`/category/${cat.slug}`)} class="category-card" style={`--cat: ${cat.color}`}>
            <div class="category-icon">{cat.icon}</div>
            <h3 class="category-name">{cat.label}</h3>
            <p class="category-desc">{cat.desc}</p>
            <span class="category-arrow">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ======================================================
       MBA Deep Dive
  ====================================================== -->
  <section class="section-block section-mba">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">経営学を深める</h2>
        <a href={url('/category/mba')} class="view-all">全記事 →</a>
      </div>
      <div class="mba-groups">
        {mbaGroupsWithPosts.map(group => (
          <div class="mba-group">
            <a href={url(`/mba/${group.slug}`)} class="mba-group-header">
              <span class="mba-group-icon">{group.icon}</span>
              <div class="mba-group-meta">
                <h3 class="mba-group-label">{group.label}</h3>
                <p class="mba-group-desc">{group.desc}</p>
              </div>
              <span class="mba-group-arrow">→</span>
            </a>
            <ul class="mba-group-list">
              {group.posts.map(post => post && (
                <li>
                  <a href={url(`/blog/${post.slug}`)} class="mba-post-link">
                    <span class="mba-post-title">{post.data.title}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ======================================================
       Interactive Novels CTA
  ====================================================== -->
  <section class="section-block section-novels">
    <div class="container">
      <div class="novels-cta">
        <div class="novels-cta-text">
          <div class="novels-cta-tag">新体験</div>
          <h2 class="novels-cta-title">動く小説を<br />読んでみませんか？</h2>
          <p class="novels-cta-desc">
            スクロールに連動したアニメーションで語られる物語。<br />
            読むのではなく、「体験する」小説の世界へ。
          </p>
          <a href={url('/novels')} class="btn btn-primary">小説を読む</a>
        </div>
        <div class="novels-cta-visual" aria-hidden="true">
          <div class="novel-preview">
            <div class="novel-line"></div>
            <div class="novel-line novel-line--short"></div>
            <div class="novel-line"></div>
            <div class="novel-line novel-line--medium"></div>
            <div class="novel-line novel-line--short"></div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
/* ============================================================
   Hero
   ============================================================ */
.hero {
  background: linear-gradient(135deg, #fdfcf8 0%, #f5f3ec 50%, #fdfcf8 100%);
  border-bottom: 1px solid var(--color-border);
  overflow: hidden;
  position: relative;
}
.hero::before {
  content: '';
  position: absolute;
  top: -40%;
  right: -10%;
  width: 500px;
  height: 500px;
  border-radius: 50%;
  background: radial-gradient(circle, color-mix(in srgb, var(--color-accent) 8%, transparent), transparent 70%);
  pointer-events: none;
}
.hero-inner {
  position: relative;
  z-index: 1;
  padding-top: var(--space-3xl);
  padding-bottom: var(--space-2xl);
  max-width: 680px;
}
.hero-tag {
  display: inline-block;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--color-accent);
  border: 1.5px solid var(--color-accent-dim);
  padding: 4px 14px;
  border-radius: 100px;
  margin-bottom: var(--space-xl);
  background: var(--color-accent-bg);
}
.hero-title {
  font-size: clamp(2rem, 5vw, 3.25rem);
  font-weight: 700;
  line-height: 1.25;
  letter-spacing: -0.02em;
  color: var(--color-text);
  margin-bottom: var(--space-xl);
}
.hero-lead {
  font-size: clamp(0.95rem, 2vw, 1.05rem);
  color: var(--color-text-muted);
  line-height: 1.9;
  margin-bottom: var(--space-2xl);
}
.hero-lead strong { color: var(--color-accent); font-weight: 700; }
.hero-actions { display: flex; gap: var(--space-md); flex-wrap: wrap; }

/* Scroll hint */
.scroll-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  padding: var(--space-xl) 0 var(--space-2xl);
  color: var(--color-accent);
  animation: scrollHintFade 2.8s ease-in-out infinite;
}
.scroll-hint-text { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.35em; }
.scroll-hint-line {
  width: 2px; height: 52px;
  background: color-mix(in srgb, var(--color-accent) 20%, transparent);
  border-radius: 2px; position: relative; overflow: hidden;
}
.scroll-hint-dot {
  position: absolute; top: -8px; left: 50%; transform: translateX(-50%);
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--color-accent);
  animation: scrollDotDrop 2.8s ease-in-out infinite;
}
@keyframes scrollHintFade { 0%,100%{opacity:.4} 50%{opacity:1} }
@keyframes scrollDotDrop { 0%{top:-8px;opacity:0} 20%{opacity:1} 80%{opacity:.6} 100%{top:52px;opacity:0} }

/* ============================================================
   Section blocks — unified beige background alternating
   ============================================================ */
.section-block { padding: var(--space-3xl) 0; }

.section-latest  { background: #fdfcf8; border-bottom: 1px solid var(--color-border); }
.section-popular { background: #f5f3ec; border-bottom: 1px solid var(--color-border); }
.section-categories { background: #fdfcf8; border-bottom: 1px solid var(--color-border); }
.section-mba    { background: #f5f3ec; border-bottom: 1px solid var(--color-border); }
.section-novels { background: #fdfcf8; }

.ad-wrap { padding: var(--space-lg) var(--space-lg) 0; }

/* ============================================================
   Section headings
   ============================================================ */
.section-title {
  font-size: 1.375rem;
  font-weight: 700;
  color: var(--color-text);
  position: relative;
  padding-left: var(--space-md);
}
.section-title::before {
  content: '';
  position: absolute;
  left: 0; top: 50%; transform: translateY(-50%);
  width: 3px; height: 1.1em;
  background: var(--color-accent);
  border-radius: 2px;
}
.section-title--center {
  padding-left: 0;
  text-align: center;
  margin-bottom: var(--space-xl);
}
.section-title--center::before { display: none; }

.section-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: var(--space-xl);
}
.view-all { font-size: 0.875rem; font-weight: 600; color: var(--color-accent); text-decoration: none; }
.view-all:hover { opacity: 0.8; }

/* ============================================================
   Grids
   ============================================================ */
.posts-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-lg); }
.featured-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-lg); }

/* ============================================================
   Category Grid
   ============================================================ */
.category-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-lg);
}
.category-card {
  display: flex; flex-direction: column; gap: var(--space-sm);
  background: var(--color-bg);
  border: 1.5px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: var(--space-xl);
  text-decoration: none; color: inherit;
  transition: border-color var(--transition-md), transform var(--transition-md), box-shadow var(--transition-md);
  box-shadow: var(--shadow-sm);
  position: relative; overflow: hidden;
}
.category-card::after {
  content: '';
  position: absolute; top: 0; left: 0; width: 100%; height: 3px;
  background: var(--cat, var(--color-accent));
  transform: scaleX(0); transform-origin: left;
  transition: transform var(--transition-md);
}
.category-card:hover { border-color: var(--color-border-light); transform: translateY(-4px); box-shadow: var(--shadow-lg); }
.category-card:hover::after { transform: scaleX(1); }
.category-icon { font-size: 2rem; }
.category-name { font-size: 1rem; font-weight: 700; color: var(--color-text); }
.category-desc { font-size: 0.8rem; color: var(--color-text-muted); line-height: 1.6; flex: 1; }
.category-arrow { font-size: 1.1rem; font-weight: 700; color: var(--cat, var(--color-accent)); margin-top: auto; }

/* ============================================================
   MBA Sub-categories
   ============================================================ */
.mba-groups {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-lg);
}
.mba-group {
  background: var(--color-bg);
  border: 1.5px solid var(--color-border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: box-shadow var(--transition-md), border-color var(--transition-md);
}
.mba-group:hover { border-color: var(--cat-mba); box-shadow: var(--shadow-lg); }

.mba-group-header {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  padding: var(--space-lg) var(--space-xl);
  background: color-mix(in srgb, var(--cat-mba) 6%, white);
  border-bottom: 1px solid var(--color-border);
  text-decoration: none;
  color: inherit;
  transition: background var(--transition-fast);
}
.mba-group-header:hover { background: color-mix(in srgb, var(--cat-mba) 12%, white); }
.mba-group-icon { font-size: 1.5rem; flex-shrink: 0; }
.mba-group-meta { flex: 1; }
.mba-group-label { font-size: 1rem; font-weight: 700; color: var(--color-text); }
.mba-group-desc { font-size: 0.72rem; color: var(--color-text-faint); line-height: 1.4; margin-top: 2px; }
.mba-group-arrow { font-size: 1rem; font-weight: 700; color: var(--cat-mba); flex-shrink: 0; }

.mba-group-list {
  list-style: none; margin: 0; padding: var(--space-md) var(--space-xl);
  display: flex; flex-direction: column; gap: 2px;
  flex: 1;
}
.mba-post-link {
  display: block;
  font-size: 0.82rem;
  color: var(--color-text-muted);
  line-height: 1.5;
  padding: 6px 0;
  border-bottom: 1px dashed var(--color-border);
  text-decoration: none;
  transition: color var(--transition-fast);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.mba-post-link:hover { color: var(--cat-mba); }
li:last-child .mba-post-link { border-bottom: none; }

/* ============================================================
   Novels CTA
   ============================================================ */
.novels-cta {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-2xl);
  align-items: center;
  background: color-mix(in srgb, var(--cat-novel) 6%, white);
  border: 1.5px solid color-mix(in srgb, var(--cat-novel) 25%, var(--color-border));
  border-radius: var(--radius-lg);
  padding: var(--space-2xl);
  box-shadow: var(--shadow-sm);
}
.novels-cta-tag {
  font-size: 0.7rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase;
  color: var(--cat-novel); border: 1.5px solid var(--cat-novel);
  display: inline-block; padding: 3px 12px; border-radius: 100px;
  margin-bottom: var(--space-lg); background: white;
}
.novels-cta-title {
  font-family: var(--font-serif);
  font-size: clamp(1.5rem, 3vw, 2rem);
  line-height: 1.4; margin-bottom: var(--space-lg); color: var(--color-text);
}
.novels-cta-desc { color: var(--color-text-muted); line-height: 1.8; margin-bottom: var(--space-xl); }
.novels-cta-visual { display: flex; justify-content: center; align-items: center; }
.novel-preview { display: flex; flex-direction: column; gap: 12px; width: 100%; max-width: 280px; }
.novel-line { height: 2px; background: var(--cat-novel); border-radius: 1px; opacity: 0.4; animation: novelPulse 2.5s ease-in-out infinite; }
.novel-line--short { width: 45%; }
.novel-line--medium { width: 70%; }
.novel-line:nth-child(2) { animation-delay: 0.4s; }
.novel-line:nth-child(3) { animation-delay: 0.8s; }
.novel-line:nth-child(4) { animation-delay: 1.2s; }
.novel-line:nth-child(5) { animation-delay: 1.6s; }
@keyframes novelPulse { 0%,100%{opacity:.15} 50%{opacity:.6} }

/* ============================================================
   Responsive
   ============================================================ */
.br-desktop { display: block; }

@media (max-width: 1024px) {
  .category-grid { grid-template-columns: repeat(2, 1fr); }
  .posts-grid { grid-template-columns: repeat(2, 1fr); }
  .mba-groups { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 768px) {
  .featured-grid { grid-template-columns: 1fr; }
  .novels-cta { grid-template-columns: 1fr; }
  .novels-cta-visual { display: none; }
  .br-desktop { display: none; }
  .mba-groups { grid-template-columns: 1fr; }
}
@media (max-width: 480px) {
  .category-grid { grid-template-columns: repeat(2, 1fr); }
  .posts-grid { grid-template-columns: 1fr; }
}
</style>
