---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection('blog', ({ data }) =>
    !data.draft && (data.isNovel === true || data.categorySlug === 'novel')
  );
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
};

const { post } = Astro.props;
const { title, description, pubDate, keywords } = post.data;
const { Content } = await post.render();

const formattedDate = pubDate.toLocaleDateString('ja-JP', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<BaseLayout title={title} description={description} keywords={keywords}>
  <div class="novel-viewer">
    <!-- Novel Header -->
    <header class="novel-header">
      <a href="/novels" class="novel-back">← 小説一覧へ</a>
      <div class="novel-header-content">
        <p class="novel-date">{formattedDate}</p>
        <h1 class="novel-title">{title}</h1>
        <p class="novel-desc">{description}</p>
      </div>
    </header>

    <!-- Scroll Progress Bar -->
    <div class="scroll-progress" id="scroll-progress" aria-hidden="true">
      <div class="scroll-progress-bar" id="scroll-progress-bar"></div>
    </div>

    <!-- Novel Body -->
    <div class="novel-body" id="novel-body">
      <div class="novel-prose prose">
        <Content />
      </div>
    </div>

    <!-- Novel Footer -->
    <footer class="novel-footer">
      <a href="/novels" class="btn btn-outline">← 小説一覧へ戻る</a>
    </footer>
  </div>
</BaseLayout>

<style>
.novel-viewer {
  min-height: 100vh;
  background: var(--color-bg);
}

/* Header */
.novel-header {
  padding: var(--space-2xl) var(--space-lg);
  max-width: 680px;
  margin-inline: auto;
  text-align: center;
}

.novel-back {
  display: inline-block;
  font-size: 0.85rem;
  color: var(--color-text-faint);
  text-decoration: none;
  margin-bottom: var(--space-2xl);
  transition: color var(--transition-fast);
}
.novel-back:hover { color: var(--cat-novel); }

.novel-date {
  font-size: 0.8rem;
  color: var(--color-text-faint);
  letter-spacing: 0.1em;
  margin-bottom: var(--space-lg);
}

.novel-title {
  font-family: var(--font-serif);
  font-size: clamp(1.75rem, 5vw, 3rem);
  font-weight: 700;
  line-height: 1.3;
  margin-bottom: var(--space-lg);
  color: var(--color-text);
}

.novel-desc {
  font-size: 0.95rem;
  color: var(--color-text-muted);
  line-height: 1.8;
  max-width: 480px;
  margin-inline: auto;
}

/* Scroll Progress */
.scroll-progress {
  position: fixed;
  top: var(--header-height);
  left: 0;
  right: 0;
  height: 2px;
  background: var(--color-border);
  z-index: 99;
}
.scroll-progress-bar {
  height: 100%;
  background: linear-gradient(90deg, var(--cat-novel), var(--color-accent));
  width: 0%;
  transition: width 0.1s linear;
}

/* Novel body */
.novel-body {
  max-width: 640px;
  margin-inline: auto;
  padding: var(--space-2xl) var(--space-lg) var(--space-3xl);
}

/* Override prose for novel reading experience */
.novel-prose {
  font-family: var(--font-serif);
  font-size: 1.05rem;
  line-height: 2.2;
  color: var(--color-text);
}

/* Paragraph reveal animation - applied by JS */
.novel-prose :global(p),
.novel-prose :global(h2),
.novel-prose :global(h3),
.novel-prose :global(hr) {
  opacity: 0;
  transform: translateY(16px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.novel-prose :global(.revealed) {
  opacity: 1;
  transform: translateY(0);
}

/* Dividers as scene breaks */
.novel-prose :global(hr) {
  border: none;
  text-align: center;
  margin: var(--space-2xl) 0;
}
.novel-prose :global(hr)::after {
  content: '✦ ✦ ✦';
  color: var(--color-text-faint);
  font-size: 0.75rem;
  letter-spacing: 0.5em;
}

.novel-footer {
  padding: var(--space-2xl) var(--space-lg) var(--space-3xl);
  text-align: center;
}
</style>

<script>
// Scroll progress bar
const progressBar = document.getElementById('scroll-progress-bar');
window.addEventListener('scroll', () => {
  const scrollTop = window.scrollY;
  const docHeight = document.documentElement.scrollHeight - window.innerHeight;
  const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
  if (progressBar) progressBar.style.width = `${progress}%`;
}, { passive: true });

// Paragraph reveal on scroll (IntersectionObserver)
const elements = document.querySelectorAll('.novel-prose p, .novel-prose h2, .novel-prose h3, .novel-prose hr');

const observer = new IntersectionObserver(
  (entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('revealed');
        observer.unobserve(entry.target);
      }
    });
  },
  { threshold: 0.1, rootMargin: '0px 0px -10% 0px' }
);

elements.forEach(el => observer.observe(el));
</script>
