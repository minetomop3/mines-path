---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { url } from '../../utils/url';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection('blog', ({ data }) =>
    !data.draft && (data.isNovel === true || data.categorySlug === 'novel')
  );
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
};

const { post } = Astro.props;
const { title, description, pubDate, keywords } = post.data;
const { Content } = await post.render();

const formattedDate = pubDate.toLocaleDateString('ja-JP', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<BaseLayout title={title} description={description} keywords={keywords}>
  <div class="novel-viewer">
    <div class="progress-container" aria-hidden="true">
      <div class="progress-bar" id="progress-bar"></div>
    </div>

    <a href={url('/novels')} class="novel-back">← 小説一覧へ</a>

    <header class="novel-header">
      <div class="content-container">
        <p class="novel-date">{formattedDate}</p>
        <h1 class="novel-title">{title}</h1>
        <p class="novel-desc">{description}</p>
      </div>
    </header>

    <div class="novel-body content-container">
      <div class="novel-prose prose">
        <Content />
      </div>
    </div>

    <footer class="novel-footer">
      <a href={url('/novels')} class="btn btn-outline">← 小説一覧へ戻る</a>
    </footer>
  </div>
</BaseLayout>

<style>
.novel-viewer { min-height: 100vh; }
.progress-container { position: fixed; top: var(--header-height); left: 0; right: 0; height: 2px; background: var(--color-border); z-index: 99; }
.progress-bar { height: 100%; background: linear-gradient(90deg, var(--cat-novel), var(--color-accent)); width: 0%; transition: width 0.1s linear; }
.novel-back { position: fixed; top: calc(var(--header-height) + 16px); left: 24px; z-index: 98; font-size: 0.8rem; color: var(--color-text-faint); text-decoration: none; transition: color var(--transition-fast); }
.novel-back:hover { color: var(--cat-novel); }
.novel-header { padding: var(--space-3xl) 0 var(--space-xl); border-bottom: 1px solid var(--color-border); margin-bottom: var(--space-xl); text-align: center; background: linear-gradient(to bottom, var(--color-surface), var(--color-bg)); }
.novel-date { font-size: 0.8rem; color: var(--color-text-faint); letter-spacing: 0.1em; margin-bottom: var(--space-lg); }
.novel-title { font-family: var(--font-serif); font-size: clamp(1.75rem, 5vw, 3rem); font-weight: 700; line-height: 1.3; margin-bottom: var(--space-lg); color: var(--color-text); }
.novel-desc { font-size: 0.95rem; color: var(--color-text-muted); line-height: 1.8; max-width: 480px; margin-inline: auto; }
.novel-body { padding: var(--space-2xl) var(--space-lg) var(--space-3xl); }
.novel-prose { font-family: var(--font-serif); font-size: 1.05rem; line-height: 2.2; }
.novel-prose :global(p) { opacity: 0; transform: translateY(16px); transition: opacity 0.7s ease, transform 0.7s ease; margin-bottom: var(--space-lg); }
.novel-prose :global(.revealed) { opacity: 1; transform: translateY(0); }
.novel-prose :global(hr) { border: none; text-align: center; margin: var(--space-2xl) 0; opacity: 0; transition: opacity 0.7s ease; }
.novel-prose :global(hr.revealed) { opacity: 1; }
.novel-prose :global(hr)::after { content: '✦ ✦ ✦'; color: var(--color-text-faint); font-size: 0.75rem; letter-spacing: 0.5em; }
.novel-footer { padding: var(--space-2xl) var(--space-lg) var(--space-3xl); text-align: center; }
</style>

<script>
const progressBar = document.getElementById('progress-bar');
window.addEventListener('scroll', () => {
  const pct = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
  if (progressBar) progressBar.style.width = `${pct}%`;
}, { passive: true });

const observer = new IntersectionObserver(
  entries => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('revealed'); observer.unobserve(e.target); } }),
  { threshold: 0.1, rootMargin: '0px 0px -10% 0px' }
);
document.querySelectorAll('.novel-prose p, .novel-prose hr').forEach(el => observer.observe(el));
</script>
