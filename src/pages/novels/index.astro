---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { url } from '../../utils/url';

const novelCategoryPosts = (await getCollection('blog', ({ data }) =>
  !data.draft && data.categorySlug === 'novel'
)).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Interactive Novels — 動く小説"
  description="スクロールアニメーションで語られる没入感のある物語。読むのではなく体験する、新しい小説の形。"
>
  <div class="novels-page">
    <section class="novels-hero">
      <div class="content-container">
        <div class="novels-hero-tag">Interactive Novels</div>
        <h1 class="novels-hero-title">
          <span class="novels-hero-title-jp">動く小説</span>
        </h1>
        <p class="novels-hero-desc">
          スクロールに呼応して言葉が現れる、没入感のある物語の体験。<br />
          読むのではなく、<em>感じる</em>小説の世界へ。
        </p>
      </div>
    </section>

    <section class="novels-list container">
      {novelCategoryPosts.length > 0 ? (
        <div class="novels-grid">
          {novelCategoryPosts.map(novel => (
            <a href={url(`/novels/${novel.slug}`)} class="novel-card">
              <div class="novel-card-content">
                <div class="novel-card-meta">
                  <time datetime={novel.data.pubDate.toISOString()}>
                    {novel.data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                </div>
                <h2 class="novel-card-title">{novel.data.title}</h2>
                <p class="novel-card-desc">{novel.data.description}</p>
                <span class="novel-card-cta">読む →</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="novels-empty">
          <p>小説は準備中です。</p>
        </div>
      )}
    </section>

    <section class="novels-sample container">
      <div class="sample-card">
        <h2>インタラクティブ体験を試してみる</h2>
        <p>スクロール連動アニメーションのデモページをご用意しています。</p>
        <a href={url('/novels/demo')} class="btn btn-primary">デモを体験する</a>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
.novels-hero { padding: var(--space-3xl) 0 var(--space-2xl); border-bottom: 1px solid var(--color-border); background: linear-gradient(135deg, #f5f3ec, #fdfcf8); }
.novels-hero .content-container { padding: 0 var(--space-lg); }
.novels-hero-tag { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--cat-novel); margin-bottom: var(--space-xl); }
.novels-hero-title { font-size: clamp(2.5rem, 7vw, 4rem); font-weight: 700; line-height: 1.1; margin-bottom: var(--space-xl); }
.novels-hero-title-jp { font-family: var(--font-serif); color: var(--color-text); }
.novels-hero-desc { font-size: 1.05rem; color: var(--color-text-muted); line-height: 1.9; max-width: 500px; }
.novels-hero-desc em { font-style: italic; color: var(--cat-novel); }
.novels-list { padding: var(--space-2xl) var(--space-lg); }
.novels-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-xl); }
.novel-card { display: block; border: 1.5px solid var(--color-border); border-radius: var(--radius-lg); overflow: hidden; text-decoration: none; color: inherit; min-height: 220px; transition: border-color var(--transition-md), transform var(--transition-md), box-shadow var(--transition-md); background: var(--color-bg); box-shadow: var(--shadow-sm); }
.novel-card:hover { border-color: var(--cat-novel); transform: translateY(-4px); box-shadow: var(--shadow-lg); }
.novel-card-content { padding: var(--space-xl); display: flex; flex-direction: column; gap: var(--space-sm); }
.novel-card-meta { font-size: 0.75rem; color: var(--color-text-faint); }
.novel-card-title { font-family: var(--font-serif); font-size: 1.4rem; font-weight: 700; line-height: 1.4; color: var(--color-text); }
.novel-card:hover .novel-card-title { color: var(--cat-novel); }
.novel-card-desc { font-size: 0.875rem; color: var(--color-text-muted); line-height: 1.7; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 0; }
.novel-card-cta { font-size: 0.875rem; font-weight: 600; color: var(--cat-novel); margin-top: auto; }
.novels-sample { padding: 0 var(--space-lg) var(--space-3xl); }
.sample-card { background: color-mix(in srgb, var(--cat-novel) 6%, white); border: 1.5px solid color-mix(in srgb, var(--cat-novel) 25%, var(--color-border)); border-radius: var(--radius-lg); padding: var(--space-2xl); }
.sample-card h2 { font-size: 1.375rem; margin-bottom: var(--space-md); }
.sample-card p { color: var(--color-text-muted); margin-bottom: var(--space-xl); }
.novels-empty { text-align: center; padding: var(--space-3xl); color: var(--color-text-muted); }
@media (max-width: 768px) { .novels-grid { grid-template-columns: 1fr; } }
</style>
