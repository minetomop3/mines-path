---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';

interface Props {
  currentPost: CollectionEntry<'blog'>;
}

const { currentPost } = Astro.props;
const { categorySlug, related } = currentPost.data;

const allPosts = await getCollection('blog', ({ data }) => !data.draft);

let relatedPosts: CollectionEntry<'blog'>[] = [];

// 1. frontmatterのrelated指定を優先
if (related.length > 0) {
  const specified = related
    .map(slug => allPosts.find(p => p.slug === slug))
    .filter((p): p is CollectionEntry<'blog'> => !!p);
  relatedPosts.push(...specified);
}

// 2. 足りない分は別カテゴリから補う
if (relatedPosts.length < 2) {
  const otherCats = allPosts
    .filter(p =>
      p.slug !== currentPost.slug &&
      p.data.categorySlug !== categorySlug &&
      !relatedPosts.find(r => r.slug === p.slug)
    )
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  relatedPosts.push(...otherCats.slice(0, 2 - relatedPosts.length));
}

// 最大2件
relatedPosts = relatedPosts.slice(0, 2);
---

{relatedPosts.length > 0 && (
  <aside class="related-posts">
    <h2 class="related-title">あわせて読みたい</h2>
    <div class="related-grid">
      {relatedPosts.map(post => (
        <a href={`/blog/${post.slug}`} class="related-card">
          <span class="related-cat" data-category={post.data.categorySlug}>{post.data.category}</span>
          <p class="related-card-title">{post.data.title}</p>
          <p class="related-card-desc">{post.data.description}</p>
          <span class="related-cta">読む →</span>
        </a>
      ))}
    </div>
  </aside>
)}

<style>
.related-posts {
  margin-top: var(--space-3xl);
  padding-top: var(--space-2xl);
  border-top: 2px solid var(--color-border);
}
.related-title {
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: var(--space-xl);
  padding-left: var(--space-md);
  border-left: 3px solid var(--color-accent);
}
.related-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-lg);
}
.related-card {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  padding: var(--space-xl);
  background: var(--color-surface);
  border: 1.5px solid var(--color-border);
  border-radius: var(--radius-lg);
  text-decoration: none;
  color: inherit;
  transition: border-color var(--transition-md), transform var(--transition-md), box-shadow var(--transition-md);
}
.related-card:hover {
  border-color: var(--color-accent);
  transform: translateY(-3px);
  box-shadow: var(--shadow-lg);
}
.related-cat {
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--color-accent);
}
.related-card-title {
  font-size: 0.975rem;
  font-weight: 700;
  color: var(--color-text);
  line-height: 1.5;
}
.related-card:hover .related-card-title { color: var(--color-accent); }
.related-card-desc {
  font-size: 0.8rem;
  color: var(--color-text-muted);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  flex: 1;
}
.related-cta {
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--color-accent);
  margin-top: var(--space-xs);
}
@media (max-width: 600px) {
  .related-grid { grid-template-columns: 1fr; }
}
</style>
