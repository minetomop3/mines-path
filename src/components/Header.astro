---
import { url } from '../utils/url';

const navLinks = [
  { href: url('/blog'), label: 'Blog' },
  { href: url('/category/mba'), label: '経営学' },
  { href: url('/category/tech'), label: 'AI・Tech' },
  { href: url('/category/essay'), label: 'エッセイ' },
  { href: url('/novels'), label: '小説' },
  { href: url('/about'), label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="header-inner container">
    <a href={url('/')} class="logo" aria-label="ホームへ">
      <span class="logo-mark">◈</span>
      <span class="logo-text">
        <span class="logo-main">mines-path</span>
        <span class="logo-sub">豊かさを創る、自分と道</span>
      </span>
    </a>

    <nav class="nav-desktop" aria-label="メインナビゲーション">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={['nav-link', { active: currentPath.startsWith(link.href) }]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <button class="nav-toggle" aria-label="メニューを開く" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <nav class="nav-mobile" aria-label="モバイルナビゲーション" aria-hidden="true">
    {navLinks.map(link => (
      <a
        href={link.href}
        class:list={['nav-mobile-link', { active: currentPath.startsWith(link.href) }]}
      >
        {link.label}
      </a>
    ))}
  </nav>
</header>

<style>
.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--color-border);
  box-shadow: 0 1px 0 var(--color-border);
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: var(--header-height);
  gap: var(--space-xl);
}

.logo {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  color: var(--color-text);
  font-weight: 700;
  white-space: nowrap;
  text-decoration: none;
  transition: color var(--transition-fast);
}
.logo:hover { color: var(--color-accent); }
.logo-mark { font-size: 1.3rem; color: var(--color-accent); }
.logo-text { display: flex; flex-direction: column; gap: 0; line-height: 1.1; }
.logo-main { font-size: 1rem; font-weight: 700; letter-spacing: 0.02em; }
.logo-sub { font-size: 0.62rem; font-weight: 400; color: var(--color-text-faint); letter-spacing: 0.04em; }

.nav-desktop { display: flex; align-items: center; gap: 2px; }
.nav-link {
  padding: 6px var(--space-md);
  border-radius: var(--radius-sm);
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-text-muted);
  text-decoration: none;
  transition: color var(--transition-fast), background var(--transition-fast);
}
.nav-link:hover { color: var(--color-text); background: var(--color-surface); }
.nav-link.active { color: var(--color-accent); background: var(--color-accent-bg); font-weight: 600; }

.nav-toggle {
  display: none;
  flex-direction: column;
  justify-content: center;
  gap: 5px;
  width: 36px;
  height: 36px;
  background: transparent;
  border: none;
  cursor: pointer;
  padding: 4px;
  border-radius: var(--radius-sm);
}
.nav-toggle span { display: block; height: 2px; background: var(--color-text-muted); border-radius: 1px; transition: all var(--transition-md); }
.nav-toggle:hover span { background: var(--color-text); }

.nav-mobile { display: flex; flex-direction: column; max-height: 0; overflow: hidden; transition: max-height var(--transition-slow); background: var(--color-bg); }
.nav-mobile.open { max-height: 400px; border-bottom: 1px solid var(--color-border); }
.nav-mobile-link { padding: var(--space-md) var(--space-lg); font-size: 1rem; font-weight: 500; color: var(--color-text-muted); text-decoration: none; border-top: 1px solid var(--color-border); transition: color var(--transition-fast), background var(--transition-fast); }
.nav-mobile-link:hover { color: var(--color-text); background: var(--color-surface); }
.nav-mobile-link.active { color: var(--color-accent); background: var(--color-accent-bg); }

@media (max-width: 720px) {
  .nav-desktop { display: none; }
  .nav-toggle { display: flex; }
}
</style>

<script>
const toggle = document.querySelector('.nav-toggle');
const navMobile = document.querySelector('.nav-mobile');
toggle?.addEventListener('click', () => {
  const isOpen = navMobile?.classList.toggle('open');
  toggle.setAttribute('aria-expanded', String(isOpen));
  navMobile?.setAttribute('aria-hidden', String(!isOpen));
});
</script>
