---
interface Props {
  slot?: 'header' | 'sidebar' | 'in-article' | 'footer';
  adSlot?: string;
  label?: string;
}

const { slot = 'in-article', adSlot, label } = Astro.props;

const PUB_ID = 'ca-pub-4015964879475374';

const formatBySlot: Record<string, string> = {
  header:     'auto',
  sidebar:    'auto',
  'in-article': 'fluid',
  footer:     'auto',
};

const adFormat = formatBySlot[slot] ?? 'auto';
const layout = slot === 'in-article' ? 'in-article' : undefined;
---

<div class={`ad-container ad-${slot}`} aria-label="広告エリア">
  <ins
    class="adsbygoogle"
    style="display:block"
    data-ad-client={PUB_ID}
    data-ad-slot={adSlot ?? '0000000000'}
    data-ad-format={adFormat}
    data-ad-layout={layout}
    data-full-width-responsive="true"
  ></ins>
  <span class="ad-fallback">{label ?? 'スポンサー広告'}</span>
</div>

<script is:inline>
  (function () {
    try {
      (window.adsbygoogle = window.adsbygoogle || []).push({});
    } catch (e) {
      // AdSense not loaded yet; ignore
    }
  })();
</script>

<style>
.ad-container {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-surface);
  border: 1px dashed var(--color-border-light);
  border-radius: var(--radius-md);
  color: var(--color-text-faint);
  font-size: 0.72rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  font-weight: 500;
  margin: var(--space-xl) 0;
  overflow: hidden;
}

.ad-fallback {
  position: absolute;
  z-index: 0;
  pointer-events: none;
  opacity: 0.6;
}

.adsbygoogle {
  position: relative;
  z-index: 1;
  width: 100%;
}

.ad-header, .ad-footer {
  width: 100%;
  min-height: 90px;
}
.ad-sidebar {
  width: 300px;
  min-height: 250px;
}
.ad-in-article {
  width: 100%;
  min-height: 90px;
}
</style>
